ENV=development
SECRET_KEY=change-in-production-use-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
DOCS_ENABLED=true
TRUSTED_PROXY_IPS=

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=manus
DATABASE_MAINTENANCE_NAME=postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

INITIAL_USERNAME=admin
INITIAL_PASSWORD=admin
INITIAL_PERMISSIONS=15

# Redis (Nautobot device bulk cache)
MANUS_REDIS_HOST=localhost
MANUS_REDIS_PORT=6379
MANUS_REDIS_PASSWORD=changeme
# Optional overrides:
# MANUS_REDIS_URL=redis://:changeme@localhost:6379/0
# MANUS_REDIS_KEY_PREFIX=manus-cache

# Hatchet workflow engine
# Get token: docker compose up -d, then http://localhost:8888 → Settings → API Tokens
HATCHET_CLIENT_TOKEN=<paste token here>
HATCHET_CLIENT_HOST_PORT=localhost:7077
HATCHET_CLIENT_TLS_STRATEGY=none
HATCHET_CLIENT_DEBUG=true

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Workflow run retention (scripts/purge_retention.py — schedule via cron)
RUN_RETENTION_ENABLED=false
RUN_RETENTION_DAYS=90
RUN_RETENTION_BATCH_SIZE=500
