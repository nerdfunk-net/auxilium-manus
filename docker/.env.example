# Docker Compose Environment Variables
# Copy this file to .env and customize as needed.
#
# Compose hardcodes in-container service hostnames (postgres, redis) and
# maps POSTGRES_* into DATABASE_* for the app. Bind address, backend port,
# BACKEND_URL, and NODE_ENV are set by supervisord inside the image.

# Host port for the Next.js UI (container listens on 3000)
FRONTEND_PORT=3000

# Application
ENV=development
SECRET_KEY=change-in-production-use-at-least-32-characters
INITIAL_USERNAME=admin
INITIAL_PASSWORD=admin
LOG_LEVEL=INFO
DOCS_ENABLED=true

# Credential vault (recommended in production; falls back to SECRET_KEY if unset)
# CREDENTIAL_ENCRYPTION_KEY=

# PostgreSQL (app database — used by the postgres service and mapped to DATABASE_*)
POSTGRES_DB=manus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis (host/port are fixed to the redis service in compose)
MANUS_REDIS_PASSWORD=changeme

# Hatchet workflow engine
# Start Hatchet: cd docker/hatchet && docker compose up -d
# Create a token at http://localhost:8888 → Settings → API Tokens
# Use hatchet-engine:7070 when app containers share the backend network (recommended).
HATCHET_CLIENT_TOKEN=your_hatchet_token_here
HATCHET_CLIENT_HOST_PORT=hatchet-engine:7070
HATCHET_CLIENT_TLS_STRATEGY=none
# HATCHET_CLIENT_DEBUG=false
