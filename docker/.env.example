# Docker Compose Environment Variables
# Copy this file to .env and customize as needed

# Frontend
FRONTEND_PORT=3000

# Backend (fixed at 8000 inside the container)
BACKEND_URL=http://127.0.0.1:8000

# Application
ENV=development
SECRET_KEY=change-in-production-use-at-least-32-characters
INITIAL_USERNAME=admin
INITIAL_PASSWORD=admin
LOG_LEVEL=INFO
DOCS_ENABLED=true

# PostgreSQL (app database)
POSTGRES_DB=manus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=manus
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Redis
MANUS_REDIS_HOST=redis
MANUS_REDIS_PORT=6379
MANUS_REDIS_PASSWORD=changeme

# Hatchet workflow engine
# Start Hatchet: cd docker/hatchet && docker compose up -d
# Create a token at http://localhost:8888 → Settings → API Tokens
# Use hatchet-engine:7070 when app containers share the backend network (recommended).
HATCHET_CLIENT_TOKEN=your_hatchet_token_here
HATCHET_CLIENT_HOST_PORT=hatchet-engine:7070
HATCHET_CLIENT_TLS_STRATEGY=none

# Credential vault
# CREDENTIAL_ENCRYPTION_KEY=
